{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Open PDF Studio",
  "version": "2.8.1",
  "identifier": "com.openpdfstudio.app",
  "build": {
    "frontendDist": "../dist/renderer",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:renderer",
    "beforeDevCommand": "npm run dev:renderer"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": {
      "../resources/python": "python",
      "../resources/ghostscript": "ghostscript",
      "../resources/libreoffice": "libreoffice",
      "../resources/fonts": "fonts",
      "../src/engine": "engine"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/installer-header.bmp",
        "sidebarImage": "icons/installer-sidebar.bmp",
        "displayLanguageSelector": false,
        "installerHooks": "nsis-hooks.nsh"
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJEQzlDNjNDODZBNkY2MEMKUldRTTlxYUdQTWJKdmJ6ck1IYytzQms1RjY3QW5lYjJRck52R0Q1emxIaGNFdVlOWllOdHc4N1gK",
      "endpoints": [
        "https://github.com/jasonulbright/Open-PDF-Studio/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    },
    "fs": {}
  }
}
