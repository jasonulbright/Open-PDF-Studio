{
  "name": "spectrapdf-e2e",
  "version": "0.1.0",
  "private": true,
  "description": "End-to-end test harness for Spectra PDF (WebdriverIO + tauri-driver)",
  "scripts": {
    "test": "wdio run wdio.conf.ts",
    "test:headed": "wdio run wdio.conf.ts --logLevel info",
    "build:app": "cross-env VITE_E2E=1 npx --prefix .. tauri build --debug --no-bundle"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "cross-env": "^7.0.3",
    "pdfjs-dist": "^6.0.227",
    "ts-node": "^10.9.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.4"
  }
}
