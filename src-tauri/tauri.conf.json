{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Spectra PDF",
  "version": "1.0.0",
  "identifier": "com.spectrapdf.app",
  "build": {
    "frontendDist": "../dist/renderer",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:renderer",
    "beforeDevCommand": "npm run dev:renderer"
  },
  "app": {
    "windows": [
      {
        "title": "Spectra PDF",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": {
      "../resources/python": "python",
      "../resources/ghostscript": "ghostscript",
      "../src/engine": "engine"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/installer-header.bmp",
        "sidebarImage": "icons/installer-sidebar.bmp",
        "displayLanguageSelector": false,
        "installerHooks": "nsis-hooks.nsh"
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJEQzlDNjNDODZBNkY2MEMKUldRTTlxYUdQTWJKdmJ6ck1IYytzQms1RjY3QW5lYjJRck52R0Q1emxIaGNFdVlOWllOdHc4N1gK",
      "endpoints": [
        "https://github.com/jasonulbright/spectrapdf/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    },
    "fs": {}
  }
}
